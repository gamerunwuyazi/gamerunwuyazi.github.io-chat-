{
  "name": "test-chat",
  "version": "1.0.0",
  "description": "A simple chat server",
  "main": "app.js",
  "scripts": {
    "start": "node -e \"console.log('警告：使用本命令前请先运行 npm run build 脚本，尽量使用 npm run server 命令启动')\" && node app.js",
    "server": "node esbuild.config.mjs && node app.js",
    "dev": "node esbuild.config.mjs --watch",
    "devbuild": "node esbuild.config.mjs --dev",
    "build": "node esbuild.config.mjs",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.15.1",
    "node-schedule": "^2.1.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "esbuild-minify-templates": "^0.13.1",
    "eslint": "^10.3.0"
  }
}
