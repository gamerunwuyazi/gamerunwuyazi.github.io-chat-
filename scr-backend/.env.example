# ============================================
# 数据库配置
# ============================================
# 请根据您的数据库实际情况修改以下配置
DB_HOST=localhost          # 数据库主机地址（例如：127.0.0.1 或 localhost）
DB_USER=sql_user          # 数据库用户名
DB_PASSWORD=sql_password  # 数据库密码
DB_NAME=sql_name          # 数据库名称

# ============================================
# 服务器配置
# ============================================
PORT=15825                # 服务器监听端口（HTTP和WebSocket）
NODE_ENV=                  # 环境模式: development | production（留空则由npm命令自动确定）

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost      # Redis 主机地址
REDIS_PORT=6379           # Redis 端口号
REDIS_PASSWORD=           # Redis 密码（如果设置了密码）
REDIS_URL=                # Redis 完整连接URL（优先级高于单独配置，例如：redis://:password@localhost:6379）

# ============================================
# Socket.IO WebSocket 配置
# ============================================
SOCKET_PING_TIMEOUT=60000     # Ping 超时时间（毫秒），客户端在此时间内未响应则断开连接（建议值：60000）
SOCKET_PING_INTERVAL=25000    # Ping 间隔时间（毫秒），服务器发送心跳包的间隔（建议值：25000）
SOCKET_CONNECT_TIMEOUT=45000  # 连接超时时间（毫秒），握手阶段的超时时间（建议值：45000）
SOCKET_UPGRADE_TIMEOUT=30000  # 升级超时时间（毫秒），HTTP升级到WebSocket的超时时间（建议值：30000）

# ============================================
# 速率限制配置
# ============================================
# 短期限制（10秒窗口期内的请求次数限制）
RATE_LIMIT_SHORT_WINDOW_MS=10000   # 短期窗口期时长（毫秒）（建议值：10000 = 10秒）
RATE_LIMIT_SHORT_LIMIT=10          # 短期内允许的最大请求数（建议值：10）

# 长期限制（60秒窗口期内的请求次数限制）
RATE_LIMIT_LONG_WINDOW_MS=60000    # 长期窗口期时长（毫秒）（建议值：60000 = 1分钟）
RATE_LIMIT_LONG_LIMIT=40            # 长期内允许的最大请求数（建议值：40）

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=public/uploads       # 上传文件存储目录（相对于项目根目录）
AVATAR_DIR=public/avatars       # 头像文件存储目录（相对于项目根目录）
MAX_FILE_SIZE_MB=10             # 单个文件最大大小（MB）（建议值：10）
MAX_AVATAR_SIZE_MB=2             # 头像文件最大大小（MB）（建议值：2）

# ============================================
# 会话配置
# ============================================
SESSION_EXPIRE_MINUTES=20        # 会话过期时间（分钟）（建议值：20）
REFRESH_TOKEN_EXPIRE_DAYS=7     # 刷新令牌过期时间（天）（建议值：7）
AUTO_LOGIN_EXPIRE_MINUTES=5     # 自动登录令牌过期时间（分钟）（建议值：5）

# ============================================
# 消息配置
# ============================================
MAX_MESSAGE_LENGTH=10000         # 单条消息最大字符数（建议值：10000）
OFFLINE_MESSAGES_LIMIT_PUBLIC=2500    # 公共消息离线拉取最大数量（建议值：2500）
OFFLINE_MESSAGES_LIMIT_GROUP=8000     # 群组消息离线拉取最大数量（建议值：8000）
OFFLINE_MESSAGES_LIMIT_PRIVATE=5000   # 私信消息离线拉取最大数量（建议值：5000）

# ============================================
# 定时任务配置
# ============================================
CLEANUP_CRON_SCHEDULE="0 0 2 * * *"   # 清理定时任务执行时间（Cron表达式，默认每天凌晨2点）
FILE_RETENTION_DAYS=7              # 过期文件保留天数（天）（建议值：7）

# ============================================
# 安全配置
# ============================================
ADMIN_PASSWORD=123456             # 管理员密码（用于调试接口）- 建议设置为强密码，不要使用默认值

# Cloudflare Turnstile 人机验证配置
# 需要先注册 Cloudflare 账号并创建 Turnstile 站点，获取密钥
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here  # Turnstile Secret Key（服务端验证使用）

# CORS 跨域配置
CORS_ORIGIN=*                   # 允许的源（* 表示允许所有来源，生产环境建议指定具体域名）

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info                  # 日志级别: error | warn | info | debug
